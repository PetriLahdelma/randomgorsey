# EmailJS Configuration (Next.js)
# Copy this file to .env and fill in your actual EmailJS credentials
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_service_id_here
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_template_id_here
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key_here

# Google Analytics (optional)
NEXT_PUBLIC_GA_TRACKING_ID=your_ga_tracking_id_here

# Site metadata / canonical origin
NEXT_PUBLIC_SITE_ORIGIN=https://randomgorsey.com

# Private keys (not exposed to client)
EMAILJS_PRIVATE_KEY=your_private_key_here
